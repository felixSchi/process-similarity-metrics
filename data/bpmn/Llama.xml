<testset xmlns="http://cpee.org/ns/properties/2.0">
  <executionhandler>ruby</executionhandler>
  <dataelements/>
  <endpoints>
    <user>https-post://cpee.org/services/timeout-user.php</user>
    <auto>https-post://cpee.org/services/timeout-auto.php</auto>
    <subprocess>https-post://cpee.org/flow/start/url/</subprocess>
    <timeout>https-post://cpee.org/services/timeout.php</timeout>
    <send>https-post://cpee.org/ing/correlators/message/send/</send>
    <receive>https-get://cpee.org/ing/correlators/message/receive/</receive>
  </endpoints>
  <attributes>
    <info>Plain Instance</info>
    <modeltype>ChatGPT_Mermaid</modeltype>
    <theme>preset</theme>
  </attributes>
  <description>flowchart TD
    0:startevent:((startevent)) --&gt; 1:task:(Get customer properties)
    1 --&gt; 2:parallelgateway:{AND}
    2 --&gt; |Order guide bar| 3:task:(Order guide bar)
    2 --&gt; |Order chain| 4:task:(Order chain)
    2 --&gt; |Order electric or motor parts| 5:task:(Order electric or motor parts)
    2 --&gt; |Order handle| 6:task:(Order handle)
    2 --&gt; |Order safety features| 7:task:(Order safety features)
    3 --&gt; 8:parallelgateway:{AND}
    4 --&gt; 8:parallelgateway:{AND}
    5 --&gt; 8:parallelgateway:{AND}
    6 --&gt; 8:parallelgateway:{AND}
    7 --&gt; 8:parallelgateway:{AND}
    8:parallelgateway:{AND} --&gt; 9:task:(Manual inspection of all parts)
    9 --&gt; 10:task:(Send update to customer: parts arrived)
    10 --&gt; 11:task:(Assemble parts)
    11 --&gt; 12:task:(Send update to customer: assembly in progress)
    12 --&gt; 13:task:(Send first saw to customer)
    13 --&gt; 14:task:(Get customer feedback)
    14 --&gt; 15:exclusivegateway:{x}
    15 --&gt; |Likes it| 16:task:(Produce rest of order)
    15 --&gt; |Does not like it| 17:endevent:(((endevent)))
    16 --&gt; 17
    <description xmlns="http://cpee.org/ns/description/1.0"
      xmlns:a="http://cpee.org/ns/annotation/1.0">
      <call id="a1" endpoint="" a:alt_id="1">
        <parameters>
          <label>Get customer properties</label>
          <method/>
          <type>:task</type>
          <arguments/>
        </parameters>
      </call>
      <parallel wait="-1" cancel="last" a:alt_id="2">
        <parallel_branch>
          <call id="a5" endpoint="" a:alt_id="3">
            <parameters>
              <label>Order guide bar</label>
              <method/>
              <type>:task</type>
              <arguments/>
            </parameters>
          </call>
        </parallel_branch>
        <parallel_branch>
          <call id="a7" endpoint="" a:alt_id="4">
            <parameters>
              <label>Order chain</label>
              <method/>
              <type>:task</type>
              <arguments/>
            </parameters>
          </call>
        </parallel_branch>
        <parallel_branch>
          <call id="a9" endpoint="" a:alt_id="5">
            <parameters>
              <label>Order electric or motor parts</label>
              <method/>
              <type>:task</type>
              <arguments/>
            </parameters>
          </call>
        </parallel_branch>
        <parallel_branch>
          <call id="a11" endpoint="" a:alt_id="6">
            <parameters>
              <label>Order handle</label>
              <method/>
              <type>:task</type>
              <arguments/>
            </parameters>
          </call>
        </parallel_branch>
        <parallel_branch>
          <call id="a13" endpoint="" a:alt_id="7">
            <parameters>
              <label>Order safety features</label>
              <method/>
              <type>:task</type>
              <arguments/>
            </parameters>
          </call>
        </parallel_branch>
      </parallel>
      <call id="a25" endpoint="" a:alt_id="9">
        <parameters>
          <label>Manual inspection of all parts</label>
          <method/>
          <type>:task</type>
          <arguments/>
        </parameters>
      </call>
      <call id="a27" endpoint="" a:alt_id="10">
        <parameters>
          <label>Send update to customer: parts arrived</label>
          <method/>
          <type>:task</type>
          <arguments/>
        </parameters>
      </call>
      <call id="a29" endpoint="" a:alt_id="11">
        <parameters>
          <label>Assemble parts</label>
          <method/>
          <type>:task</type>
          <arguments/>
        </parameters>
      </call>
      <call id="a31" endpoint="" a:alt_id="12">
        <parameters>
          <label>Send update to customer: assembly in progress</label>
          <method/>
          <type>:task</type>
          <arguments/>
        </parameters>
      </call>
      <call id="a33" endpoint="" a:alt_id="13">
        <parameters>
          <label>Send first saw to customer</label>
          <method/>
          <type>:task</type>
          <arguments/>
        </parameters>
      </call>
      <call id="a35" endpoint="" a:alt_id="14">
        <parameters>
          <label>Get customer feedback</label>
          <method/>
          <type>:task</type>
          <arguments/>
        </parameters>
      </call>
      <choose mode="exclusive" a:alt_id="15">
        <alternative condition="Likes it" language="text/javascript">
          <call id="a39" endpoint="" a:alt_id="16">
            <parameters>
              <label>Produce rest of order</label>
              <method/>
              <type>:task</type>
              <arguments/>
            </parameters>
          </call>
        </alternative>
        <alternative condition="Does not like it" language="text/javascript"/>
      </choose>
    </description>
  </description>
  <transformation>
    <description type="copy"/>
    <dataelements type="none"/>
    <endpoints type="none"/>
  </transformation>
</testset>